# =============================================================================
# prop-firm-scalp - Environment configuration template.
# Copy to `.env` and fill in real values. Never commit secrets.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
APP_ENV=production            # development | staging | production
APP_MODE=paper                # paper | semi_auto | full_auto
LOG_LEVEL=INFO
LOG_JSON=true
TIMEZONE=UTC

# --- TradeLocker broker -----------------------------------------------------
TL_BASE_URL=https://demo.tradelocker.com/backend-api
TL_WS_URL=wss://demo.tradelocker.com/backend-api/ws
TL_EMAIL=
TL_PASSWORD=
TL_SERVER=
TL_ACCOUNT_ID=
TL_ACCOUNT_NUM=

# --- Symbols ----------------------------------------------------------------
SYMBOLS=EURUSD,XAUUSD
PRIMARY_TIMEFRAME=M1
STRUCTURE_TIMEFRAME=M5

# --- Risk / prop-firm guardrails -------------------------------------------
ACCOUNT_BALANCE=100000
RISK_PER_TRADE_PCT=0.0035        # 0.35% per trade
MAX_DAILY_LOSS_PCT=0.01          # 1% daily drawdown circuit breaker
MAX_TOTAL_DD_PCT=0.05            # 5% overall trailing drawdown
MAX_TRADES_PER_DAY=5
MAX_CONSECUTIVE_LOSSES=3
TARGET_PROFIT_PCT_MIN=0.001      # 0.10%
TARGET_PROFIT_PCT_MAX=0.002      # 0.20%
MAX_SPREAD_PIPS_FX=1.5
MAX_SPREAD_PIPS_METALS=35
MAX_SLIPPAGE_PIPS=2

# --- Sessions (UTC hours) ---------------------------------------------------
LONDON_OPEN_UTC=07
LONDON_CLOSE_UTC=11
NY_OPEN_UTC=12
NY_CLOSE_UTC=16

# --- Persistence ------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./data/journal.db
# DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/scalp
REDIS_URL=

# --- API dashboard ----------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080

# --- Notifications ----------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# --- Telegram Interactive Bot -----------------------------------------------
# Comma-separated list of Telegram chat IDs authorized for bot commands.
# If empty, falls back to TELEGRAM_CHAT_ID above.
ADMIN_CHAT_IDS=
